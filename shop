<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GamerLog Rank Shop</title>

<style>

body{
font-family: Arial, sans-serif;
margin:0;
color:white;
text-align:center;
overflow-x:hidden;

/* Galaxy background */
background: radial-gradient(circle at bottom,#1b0033,#000000);
}

/* Moving stars */

body::before{
content:"";
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background-image:
radial-gradient(2px 2px at 20px 30px white),
radial-gradient(2px 2px at 40px 70px white),
radial-gradient(2px 2px at 90px 40px white),
radial-gradient(2px 2px at 130px 80px white),
radial-gradient(2px 2px at 160px 20px white);
background-repeat:repeat;
background-size:200px 200px;
animation:starsMove 60s linear infinite;
opacity:0.6;
z-index:-1;
}

@keyframes starsMove{
from{transform:translateY(0);}
to{transform:translateY(-1000px);}
}

h1{
margin-top:40px;
font-size:42px;
}

.discord-text{
color:red;
font-weight:bold;
}

/* Rank cards */

.container{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:35px;
padding:50px;
}

.card{
background:rgba(0,0,0,0.55);
backdrop-filter:blur(10px);
padding:25px;
border-radius:16px;
width:230px;
box-shadow:0 10px 30px rgba(0,0,0,0.6);

opacity:0;
transform:translateY(40px);
animation:showRanks 1s forwards;
}

.card:nth-child(1){animation-delay:0.2s;}
.card:nth-child(2){animation-delay:0.4s;}
.card:nth-child(3){animation-delay:0.6s;}
.card:nth-child(4){animation-delay:0.8s;}

.card:hover{
transform:translateY(-12px) scale(1.05);
transition:0.4s;
box-shadow:0 0 25px #8a2cff;
}

.rank-title{
font-size:24px;
margin-bottom:10px;
}

.price{
font-size:22px;
color:#00ffd9;
margin:10px 0;
}

/* Discord button */

button{
background:#5865F2;
border:none;
padding:12px 22px;
border-radius:8px;
font-size:16px;
color:white;
cursor:pointer;
transition:0.3s;
animation:shine 2s infinite;
}

button:hover{
transform:scale(1.1);
box-shadow:0 0 20px #5865F2;
}

/* Animations */

@keyframes showRanks{
to{
opacity:1;
transform:translateY(0);
}
}

@keyframes shine{
0%{box-shadow:0 0 5px #5865F2;}
50%{box-shadow:0 0 20px #5865F2;}
100%{box-shadow:0 0 5px #5865F2;}
}

</style>
</head>

<body>

<h1>🌌 GamerLog Premium Ranks 🌌</h1>

<p>Buy ranks through <span class="discord-text">Discord</span> 💬 and unlock amazing perks 🚀</p>

<div class="container">

<div class="card">
<div class="rank-title">✨ Prime Rank</div>
<p>Starter Premium Rank</p>
<div class="price">₹99</div>

<a href="https://discord.gg/YOUR_DISCORD_LINK">
<button>💬 Buy on Discord</button>
</a>
</div>

<div class="card">
<div class="rank-title">🔥 Epic Rank</div>
<p>Extra Commands & Kits</p>
<div class="price">₹199</div>

<a href="https://discord.gg/YOUR_DISCORD_LINK">
<button>💬 Buy on Discord</button>
</a>
</div>

<div class="card">
<div class="rank-title">🌟 VIP Rank</div>
<p>Special Abilities</p>
<div class="price">₹299</div>

<a href="https://discord.gg/YOUR_DISCORD_LINK">
<button>💬 Buy on Discord</button>
</a>
</div>

<div class="card">
<div class="rank-title">👑 God Rank</div>
<p>Ultimate Premium Access</p>
<div class="price">₹499</div>

<a href="https://discord.gg/YOUR_DISCORD_LINK">
<button>💬 Buy on Discord</button>
</a>
</div>

</div>

</body>
</html>
